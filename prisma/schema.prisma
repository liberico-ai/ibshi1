  amountVnd Decimal            @map("amount_vnd")
  category  String
  notes     String?
  plan      ProjectFinancePlan @relation(fields: [planId], references: [id], onDelete: Cascade)

  @@unique([planId, category, month, year])
  @@index([planId])
  @@map("project_cashflow_monthly")
}

model MisaSyncLog {
  id           String    @id @default(cuid())
  actionType   String    @map("action_type")
  referenceId  String    @map("reference_id")
  payload      Json?
  status       String    @default("PENDING")
  errorMessage String?   @map("error_message")
  createdAt    DateTime  @default(now()) @map("created_at")
  syncedAt     DateTime? @map("synced_at")

  @@index([status])
  @@index([referenceId])
  @@map("misa_sync_logs")
}

// ── Dynamic Workflow (Phase 1) — Task động phân cấp, chạy song song WorkflowTask ──

model Task {
  id                   String              @id @default(cuid())
  projectId            String?             @map("project_id")
  parentId             String?             @map("parent_id")
  level                Int                 @default(2)
  taskType             String              @default("FREE") @map("task_type")
  title                String
  description          String?
  status               String              @default("OPEN") // OPEN | IN_PROGRESS | DONE | RETURNED | CANCELLED
  priority             String              @default("NORMAL") // NORMAL | HIGH | URGENT
  deadline             DateTime?
  createdBy            String              @map("created_by")
  assignedAt           DateTime?           @map("assigned_at")
  startedAt            DateTime?           @map("started_at")
  submittedAt          DateTime?           @map("submitted_at")
  completedAt          DateTime?           @map("completed_at")
  completedBy          String?             @map("completed_by")
  resultData           Json?               @map("result_data")
  checklistTemplateKey String?             @map("checklist_template_key")
  checklistState       Json?               @map("checklist_state")
  hookKeys             String[]            @default([]) @map("hook_keys") // hook tự động chạy khi hoàn thành
  templateStepId       String?             @map("template_step_id")
  returnCount          Int                 @default(0) @map("return_count")
  blocked              Boolean             @default(false)
  escalated            Boolean             @default(false)
  escalatedAt          DateTime?           @map("escalated_at")
  escalatedBy          String?             @map("escalated_by")
  externalRef          String?             @unique @map("external_ref")
  externalSource       String?             @map("external_source")
  forwardedFromId      String?             @map("forwarded_from_id") // việc này được "chuyển tiếp" từ task nào (truy vết)
  bomVersionId         String?             @map("bom_version_id")
  createdAt            DateTime            @default(now()) @map("created_at")
  updatedAt            DateTime            @updatedAt @map("updated_at")
  project              Project?            @relation("ProjectDynamicTasks", fields: [projectId], references: [id])
  parent               Task?               @relation("TaskTree", fields: [parentId], references: [id])
  children             Task[]              @relation("TaskTree")
  forwardedFrom        Task?               @relation("TaskForward", fields: [forwardedFromId], references: [id])
  forwards             Task[]              @relation("TaskForward")
  assignees            TaskAssignee[]
  docs                 TaskDocRequirement[]
  history              TaskHistory[]

  @@index([projectId, status])
  @@index([parentId])
  @@index([forwardedFromId])
  @@index([status, deadline])
  @@index([status, blocked])
  @@index([escalated])
  @@map("tasks")
}

model TaskAssignee {
  id         String    @id @default(cuid())
  taskId     String    @map("task_id")
  role       String?
  userId     String?   @map("user_id")
  isPrimary  Boolean   @default(false) @map("is_primary")
  acceptedAt DateTime? @map("accepted_at")
  done       Boolean   @default(false) // người này đã hoàn thành phần của mình chưa
  doneAt     DateTime? @map("done_at")
  doneBy     String?   @map("done_by") // user thực tế bấm hoàn thành (khi giao theo role)
  outcome    String?   // RETURN_CREATOR | FORWARD — hướng người này chọn khi hoàn thành
  createdAt  DateTime  @default(now()) @map("created_at")
  task       Task      @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([taskId])
  @@index([userId])
  @@index([role])
  @@map("task_assignees")
}

model TaskDocRequirement {
  id               String   @id @default(cuid())
  taskId           String   @map("task_id")
  kind             String // MUST_READ | MUST_RETURN
  label            String
  fileAttachmentId String?  @map("file_attachment_id")
  note             String?  // nội dung trả lại (text) khi hoàn thành
  fulfilled        Boolean  @default(false) // MUST_READ: tất cả người nhận đã đọc | MUST_RETURN: đã nộp
  createdAt        DateTime @default(now()) @map("created_at")
  task             Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  acks             TaskDocAck[]

  @@index([taskId])
  @@map("task_doc_requirements")
}

// ── Lịch họp (Meeting) ──
model Meeting {
  id            String          @id @default(cuid())
  projectId     String?         @map("project_id")
  taskId        String?         @map("task_id") // tạo trực tiếp từ 1 công việc (liên kết truy vết)
  title         String
  agenda        String?
  location      String?
  startsAt      DateTime        @map("starts_at")
  endsAt        DateTime?       @map("ends_at")
  momNumber     String?         @map("mom_number") // số biên bản
  status        String          @default("SCHEDULED") // SCHEDULED | DONE | CANCELLED
  minutesNote   String?         @map("minutes_note") // biên bản họp (tóm tắt/kết luận)
  minutesData   Json?           @map("minutes_data") // MOM có cấu trúc: { preparedBy, place, items[] } — theo mẫu hệ cũ P1.2A
  createdBy     String          @map("created_by")
  createdAt     DateTime        @default(now()) @map("created_at")
  updatedAt     DateTime        @updatedAt @map("updated_at")
  project       Project?        @relation("ProjectMeetings", fields: [projectId], references: [id])
  invites       MeetingInvite[]

  @@index([projectId])
  @@index([taskId])
  @@index([startsAt])
  @@map("meetings")
}

model MeetingInvite {
  id          String    @id @default(cuid())
  meetingId   String    @map("meeting_id")
  userId      String    @map("user_id")
  status      String    @default("INVITED") // INVITED | ACCEPTED | DECLINED
  respondedAt DateTime? @map("responded_at")
  note        String?
  createdAt   DateTime  @default(now()) @map("created_at")
  meeting     Meeting   @relation(fields: [meetingId], references: [id], onDelete: Cascade)

  @@unique([meetingId, userId])
  @@index([userId])
  @@map("meeting_invites")
}

// Lưu vết: từng người nhận xác nhận đã đọc tài liệu MUST_READ
model TaskDocAck {
  id            String             @id @default(cuid())
  requirementId String             @map("requirement_id")
  userId        String             @map("user_id")
  createdAt     DateTime           @default(now()) @map("created_at")
  requirement   TaskDocRequirement @relation(fields: [requirementId], references: [id], onDelete: Cascade)

  @@unique([requirementId, userId])
  @@index([requirementId])
  @@map("task_doc_acks")
}

model TaskHistory {
  id         String   @id @default(cuid())
  taskId     String   @map("task_id")
  action     String // CREATED|ASSIGNED|STARTED|COMPLETED|RETURNED|REASSIGNED|SUBTASK_CREATED|COMMENT
  byUserId   String   @map("by_user_id")
  fromUserId String?  @map("from_user_id")
  toRole     String?  @map("to_role")
  toUserId   String?  @map("to_user_id")
  reason     String?
  meta       Json?
  createdAt  DateTime @default(now()) @map("created_at")
  task       Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([taskId])
  @@index([action, createdAt])
  @@map("task_history")
}

model RoutingSuggestion {
  id               String   @id @default(cuid())
  fromContext      String   @map("from_context")
  toRoleCode       String?  @map("to_role_code")
  toDepartmentCode String?  @map("to_department_code")
  reason           String
  weight           Int      @default(1)
  source           String   @default("WORKFLOW_SEED")
  createdAt        DateTime @default(now()) @map("created_at")

  @@index([fromContext])
  @@map("routing_suggestions")
}

// ── Phase 3: Template quy trình theo loại dự án + version ──

model WorkflowTemplate {
  id          String         @id @default(cuid())
  code        String         @unique
  name        String
  projectType String         @map("project_type") // EXTERNAL_PROD | INTERNAL_PROD | OTHER
  version     Int            @default(1)
  isActive    Boolean        @default(true) @map("is_active")
  createdAt   DateTime       @default(now()) @map("created_at")
  updatedAt   DateTime       @updatedAt @map("updated_at")
  steps       TemplateStep[]

  @@index([projectType, isActive])
  @@map("workflow_templates")
}

model TemplateStep {
  id           String           @id @default(cuid())
  templateId   String           @map("template_id")
  code         String                                 // vd P2.1
  title        String
  roleCode     String?          @map("role_code")     // role được giao mặc định
  deptCode     String?          @map("dept_code")     // phòng (suy từ role)
  orderIndex   Int              @default(0) @map("order_index")
  deadlineDays Int?             @map("deadline_days")
  taskType     String           @default("FREE") @map("task_type")
  hookKeys     String[]         @default([]) @map("hook_keys")
  nextCodes    String[]         @default([]) @map("next_codes")   // bước kế tiếp (sinh theo chuỗi)
  gateCodes    String[]         @default([]) @map("gate_codes")   // điều kiện: các bước phải xong trước
  parentCode   String?          @map("parent_code")
  template     WorkflowTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@index([templateId])
  @@map("template_steps")
}

model ApiClient {
  id            String    @id @default(cuid())
  name          String
  keyPrefix     String    @unique @map("key_prefix")
  keyHash       String    @map("key_hash")
  webhookSecret String    @map("webhook_secret")
  callbackUrl   String?   @map("callback_url")
  scopes        String[]  @default([])
  active        Boolean   @default(true)
  lastUsedAt    DateTime? @map("last_used_at")
  createdAt     DateTime  @default(now()) @map("created_at")

  @@map("api_clients")
}

model BriefingSnapshot {
  id             String    @id @default(cuid())
  weekOf         DateTime  @map("week_of")
  createdBy      String    @map("created_by")
  createdAt      DateTime  @default(now()) @map("created_at")
  publishedAt    DateTime? @map("published_at")
  kpi            Json
  tasksSnapshot  Json      @map("tasks_snapshot")
  decisions      Json
  actionItems    Json      @map("action_items")

  @@unique([weekOf])
  @@index([weekOf])
  @@map("briefing_snapshots")
}
