  sectionType  String             @map("section_type")
  categoryCode String             @map("category_code")
  itemName     String             @map("item_name")
  unit         String?
  quantity     Decimal?
  unitPrice    Decimal?           @map("unit_price")
  totalBudget  Decimal            @map("total_budget")
