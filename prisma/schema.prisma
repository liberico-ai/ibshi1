  facilityCode  String         @unique @map("facility_code")
  bankName      String         @map("bank_name")
  creditLimit   Decimal        @map("credit_limit")
  currency      String         @default("VND")
  startDate     DateTime       @map("start_date")
  endDate       DateTime       @map("end_date")
  status        String         @default("ACTIVE")
  createdAt     DateTime       @default(now()) @map("created_at")
  updatedAt     DateTime       @updatedAt @map("updated_at")
  loanContracts LoanContract[]

  @@index([status])
  @@map("credit_facilities")
}

model LoanContract {
  id               String         @id @default(cuid())
  contractCode     String         @unique @map("contract_code")
  facilityId       String         @map("facility_id")
  primaryProjectId String?        @map("primary_project_id")
  loanAmount       Decimal        @map("loan_amount")
  currency         String         @default("VND")
  interestRate     Decimal        @map("interest_rate")
  termMonths       Int            @map("term_months")
  signDate         DateTime       @map("sign_date")
  status           String         @default("ACTIVE")
  createdAt        DateTime       @default(now()) @map("created_at")
  updatedAt        DateTime       @updatedAt @map("updated_at")
  facility         CreditFacility @relation(fields: [facilityId], references: [id])
  drawdowns        LoanDrawdown[]
  project          Project?       @relation(fields: [primaryProjectId], references: [id])

  @@index([facilityId])
  @@index([primaryProjectId])
  @@map("loan_contracts")
}

model LoanDrawdown {
