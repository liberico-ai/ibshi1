generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id             String         @id @default(cuid())
  username       String         @unique
  email          String?        @unique
  passwordHash   String         @map("password_hash")
  fullName       String         @map("full_name")
  roleCode       String         @map("role_code")
  userLevel      Int            @default(2) @map("user_level")
  departmentId   String?        @map("department_id")
  telegramChatId String?        @unique @map("telegram_chat_id")
  isActive       Boolean        @default(true) @map("is_active")
  createdAt      DateTime       @default(now()) @map("created_at")
  updatedAt      DateTime       @updatedAt @map("updated_at")
  auditLogs      AuditLog[]
  employee       Employee?
  notifications  Notification[]
  department     Department?    @relation(fields: [departmentId], references: [id])
  assignedTasks  WorkflowTask[] @relation("TaskAssignee")
  welderJoints   WeldJoint[]    @relation("WelderJoints")

  @@index([roleCode])
  @@index([departmentId])
  @@map("users")
}

model Department {
  id        String       @id @default(cuid())
  code      String       @unique
  name      String
  nameEn    String       @default("") @map("name_en")
  parentId  String?      @map("parent_id")
  parent    Department?  @relation("DeptHierarchy", fields: [parentId], references: [id])
  children   Department[] @relation("DeptHierarchy")
  employees            Employee[]
  users                User[]
  workOrders           WorkOrder[]
  equipment            Equipment[]
  equipmentAssignments EquipmentAssignment[]
  toolboxTalks         ToolboxTalk[]

  @@index([parentId])
  @@map("departments")
}

model Role {
  code        String @id
  name        String
  nameEn      String @default("") @map("name_en")
  permissions Json   @default("[]")

  @@map("roles")
}

model Project {
  id                 String                   @id @default(cuid())
  projectCode        String                   @unique @map("project_code")
  projectName        String                   @map("project_name")
  clientName         String                   @map("client_name")
  productType        String                   @map("product_type")
  projectType        String                   @default("OTHER") @map("project_type") // EXTERNAL_PROD | INTERNAL_PROD | OTHER
  contractValue      Decimal?                 @map("contract_value")
  currency           String                   @default("VND")
  status             String                   @default("ACTIVE")
  startDate          DateTime?                @map("start_date")
  endDate            DateTime?                @map("end_date")
  pmUserId           String?                  @map("pm_user_id")
  description        String?
  createdAt          DateTime                 @default(now()) @map("created_at")
  updatedAt          DateTime                 @updatedAt @map("updated_at")
  boms               BillOfMaterial[]
  budgets            Budget[]
  cashflows          CashflowEntry[]
  changeEvents       ChangeEvent[]
  deliveries         DeliveryRecord[]
  packingLists       PackingList[]
  shipments          Shipment[]
  drawings           Drawing[]
  ecos               EngineeringChangeOrder[]
  itps               InspectionTestPlan[]
  inspections        Inspection[]
  invoices           Invoice[]
  lessonLearns       LessonLearned[]
  milestones         Milestone[]
  ncrs               NonConformanceReport[]
  pieceRateContracts PieceRateContract[]
  purchaseOrders     PurchaseOrder[]
  purchaseReqs       PurchaseRequest[]
  safetyIncidents    SafetyIncident[]
  workPermits        WorkPermit[]
  subcontracts       SubcontractorContract[]
  timesheets         Timesheet[]
  wbsNodes           WbsNode[]
  workOrders         WorkOrder[]
  tasks              WorkflowTask[]
  dynamicTasks       Task[]                   @relation("ProjectDynamicTasks")
  meetings           Meeting[]                @relation("ProjectMeetings")
  loanContracts      LoanContract[]
  financePlan        ProjectFinancePlan?

  @@index([status])
  @@index([pmUserId])
  @@map("projects")
}

model WbsNode {
  id        String    @id @default(cuid())
  projectId String    @map("project_id")
  parentId  String?   @map("parent_id")
  nodeCode  String    @map("node_code")
  name      String
  nameEn    String    @default("") @map("name_en")
  weight    Decimal?  @default(0)
  sortOrder Int       @default(0) @map("sort_order")
  parent    WbsNode?  @relation("WbsHierarchy", fields: [parentId], references: [id])
  children  WbsNode[] @relation("WbsHierarchy")
  project   Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, nodeCode])
  @@index([projectId])
  @@map("wbs_nodes")
}

model Milestone {
  id             String    @id @default(cuid())
  projectId      String    @map("project_id")
  name           String
  nameEn         String    @default("") @map("name_en")
  description    String?
  billingPercent Decimal?  @default(0) @map("billing_percent")
  plannedDate    DateTime? @map("planned_date")
  actualDate     DateTime? @map("actual_date")
  status         String    @default("PENDING")
  sortOrder      Int       @default(0) @map("sort_order")
  createdAt      DateTime  @default(now()) @map("created_at")
  project        Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([status])
  @@map("milestones")
}

model SubcontractorContract {
  id            String    @id @default(cuid())
  projectId     String    @map("project_id")
  contractCode  String    @unique @map("contract_code")
  vendorId      String    @map("vendor_id")
  description   String
  contractValue Decimal   @map("contract_value")
  currency      String    @default("VND")
  startDate     DateTime? @map("start_date")
  endDate       DateTime? @map("end_date")
  status        String    @default("ACTIVE")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")
  project       Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  vendor        Vendor    @relation(fields: [vendorId], references: [id])

  @@index([projectId])
  @@index([vendorId])
  @@map("subcontractor_contracts")
}

model LessonLearned {
  id             String   @id @default(cuid())
  projectId      String   @map("project_id")
  category       String
  description    String
  rootCause      String?  @map("root_cause")
  actionTaken    String?  @map("action_taken")
  recommendation String?
  submittedBy    String   @map("submitted_by")
  createdAt      DateTime @default(now()) @map("created_at")
  project        Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([category])
  @@map("lesson_learned")
}

model WorkflowTask {
  id           String    @id @default(cuid())
  projectId    String    @map("project_id")
  stepCode     String    @map("step_code")
  stepName     String    @map("step_name")
  stepNameEn   String    @default("") @map("step_name_en")
  description  String?
  assignedRole String    @map("assigned_role")
  assignedTo   String?   @map("assigned_to")
  status       String    @default("PENDING")
  priority     Int       @default(0)
  deadline     DateTime?
  startedAt    DateTime? @map("started_at")
  completedAt  DateTime? @map("completed_at")
  completedBy  String?   @map("completed_by")
  resultData   Json?     @map("result_data")
  notes        String?
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")
  assignee     User?     @relation("TaskAssignee", fields: [assignedTo], references: [id])
  project      Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([assignedRole, status])
  @@index([assignedTo, status])
  @@index([projectId, status])
  @@index([deadline])
  @@index([status])
  @@map("workflow_tasks")
}

model Notification {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  title     String
  message   String
  type      String
  isRead    Boolean  @default(false) @map("is_read")
  linkUrl   String?  @map("link_url")
  createdAt DateTime @default(now()) @map("created_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  @@index([createdAt])
  @@map("notifications")
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  action    String
  entity    String
  entityId  String?  @map("entity_id")
  changes   Json?
  ipAddress String?  @map("ip_address")
  createdAt DateTime @default(now()) @map("created_at")
  user      User     @relation(fields: [userId], references: [id])

  @@index([entity, entityId])
  @@index([userId, createdAt])
  @@map("audit_logs")
}

model Vendor {
  id             String                    @id @default(cuid())
  vendorCode     String                    @unique @map("vendor_code")
  name           String
  contactName    String?                   @map("contact_name")
  email          String?
  phone          String?
  address        String?
  country        String                    @default("VN")
  category       String
  rating         Decimal?                  @default(0)
  isActive       Boolean                   @default(true) @map("is_active")
  notes          String?
  createdAt      DateTime                  @default(now()) @map("created_at")
  updatedAt      DateTime                  @updatedAt @map("updated_at")
  invoices       Invoice[]
  millCerts      MillCertificate[]
  purchaseOrders PurchaseOrder[]
  subcontracts   SubcontractorContract[]
  drawdownLines  DrawdownBeneficiaryLine[]

  @@index([category])
  @@map("vendors")
}

model MaterialGroup {
  code       String  @id
  name       String
  parentCode String? @map("parent_code")
  level      Int
  inactive   Boolean @default(false)

  @@map("material_groups")
}

model Material {
  id             String                @id @default(cuid())
  materialCode   String                @unique @map("material_code")
  name           String
  unit           String
  category       String
  groupCode      String?               @map("group_code")
  minStock       Decimal               @default(0) @map("min_stock")
  currentStock   Decimal               @default(0) @map("current_stock")
  unitPrice      Decimal?              @map("unit_price")
  currency       String                @default("VND")
  createdAt      DateTime              @default(now()) @map("created_at")
  updatedAt      DateTime              @updatedAt @map("updated_at")
  grade          String?
  nameEn         String                @default("") @map("name_en")
  reservedStock  Decimal               @default(0) @map("reserved_stock")
  specification  String?
  status         String                @default("ACTIVE") // ACTIVE | ARCHIVE | OBSOLETE
  isProvisional  Boolean               @default(false) @map("is_provisional") // mã tạm, chờ chuẩn hóa
  createdByUnit  String?               @map("created_by_unit") // phòng/đơn vị tạo mã tạm
  aliases        MaterialCodeAlias[]
  stocks         MaterialStock[]
  bomItems       BomItem[]
  materialIssues MaterialIssue[]
  millCerts      MillCertificate[]
  poItems        PurchaseOrderItem[]
  prItems        PurchaseRequestItem[]
  stockMovements StockMovement[]

  @@index([category])
  @@index([specification])
  @@index([status])
  @@map("materials")
}

model Warehouse {
  id          String          @id @default(cuid())
  code        String          @unique
  name        String
  projectCode String?         @map("project_code") // mã dự án nếu kho gắn dự án (vd 25-VPI-I-095)
  kind        String          @default("OTHER") // PROJECT | CONSIGNED | COMMON | OTHER
  isActive    Boolean         @default(true) @map("is_active")
  createdAt   DateTime        @default(now()) @map("created_at")
  stocks      MaterialStock[]

  @@index([projectCode])
  @@map("warehouses")
}

model MaterialStock {
  id          String    @id @default(cuid())
  materialId  String    @map("material_id")
  warehouseId String    @map("warehouse_id")
  quantity    Decimal   @default(0)
  value       Decimal   @default(0)
  updatedAt   DateTime  @updatedAt @map("updated_at")
  material    Material  @relation(fields: [materialId], references: [id], onDelete: Cascade)
  warehouse   Warehouse @relation(fields: [warehouseId], references: [id], onDelete: Cascade)

  @@unique([materialId, warehouseId])
  @@index([materialId])
  @@index([warehouseId])
  @@map("material_stocks")
}

model MaterialCodeAlias {
  id         String   @id @default(cuid())
  materialId String   @map("material_id")
  aliasCode  String   @unique @map("alias_code") // mã cũ — duy nhất toàn hệ thống
  source     String // KHO | KETOAN | LEGACY_DOT | TK | TM | MANUAL
  note       String?
  createdBy  String   @map("created_by")
  createdAt  DateTime @default(now()) @map("created_at")
  material   Material @relation(fields: [materialId], references: [id], onDelete: Cascade)

  @@index([materialId])
  @@index([aliasCode])
  @@map("material_code_aliases")
}

model MaterialCodeCounter {
  prefix    String
  subgroup  String
  lastSeq   Int      @default(0) @map("last_seq")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@id([prefix, subgroup])
  @@map("material_code_counters")
}

model StockMovement {
  id          String   @id @default(cuid())
  materialId  String   @map("material_id")
  projectId   String?  @map("project_id")
  type        String
  quantity    Decimal
  reason      String
  referenceNo String?  @map("reference_no")
  performedBy String   @map("performed_by")
  notes       String?
  createdAt   DateTime @default(now()) @map("created_at")
  heatNumber  String?  @map("heat_number")
  lotNumber   String?  @map("lot_number")
  poItemId    String?  @map("po_item_id")
  material    Material @relation(fields: [materialId], references: [id])

  @@index([materialId, createdAt])
  @@index([projectId])
  @@index([type])
  @@index([heatNumber])
  @@map("stock_movements")
}

model PurchaseRequest {
  id          String                @id @default(cuid())
  prCode      String                @unique @map("pr_code")
  projectId   String                @map("project_id")
  requestedBy String                @map("requested_by")
  status      String                @default("DRAFT")
  urgency     String                @default("NORMAL")
  notes       String?
  approvedBy  String?               @map("approved_by")
  approvedAt  DateTime?             @map("approved_at")
  createdAt   DateTime              @default(now()) @map("created_at")
  updatedAt   DateTime              @updatedAt @map("updated_at")
  items       PurchaseRequestItem[]
  project     Project               @relation(fields: [projectId], references: [id])

  @@index([projectId])
  @@index([status])
  @@map("purchase_requests")
}

model PurchaseRequestItem {
  id              String          @id @default(cuid())
  prId            String          @map("pr_id")
  materialId      String          @map("material_id")
  quantity        Decimal
  requiredDate    DateTime?       @map("required_date")
  specification   String?
  notes           String?
  material        Material        @relation(fields: [materialId], references: [id])
  purchaseRequest PurchaseRequest @relation(fields: [prId], references: [id], onDelete: Cascade)

  @@index([prId])
  @@index([materialId])
  @@map("purchase_request_items")
}

model PurchaseOrder {
  id           String              @id @default(cuid())
  poCode       String              @unique @map("po_code")
  projectId    String?             @map("project_id")
  vendorId     String              @map("vendor_id")
  status       String              @default("DRAFT")
  totalValue   Decimal?            @map("total_value")
  currency     String              @default("VND")
  orderDate    DateTime?           @map("order_date")
  deliveryDate DateTime?           @map("delivery_date")
  paymentTerms String?             @map("payment_terms")
  sourceTaskId String?             @map("source_task_id")
  createdBy    String              @map("created_by")
  notes        String?
  createdAt    DateTime            @default(now()) @map("created_at")
  updatedAt    DateTime            @updatedAt @map("updated_at")
  items        PurchaseOrderItem[]
  project      Project?            @relation(fields: [projectId], references: [id])
  vendor       Vendor              @relation(fields: [vendorId], references: [id])

  @@index([projectId])
  @@index([vendorId])
  @@index([status])
  @@map("purchase_orders")
}

model PurchaseOrderItem {
  id            String        @id @default(cuid())
  poId          String        @map("po_id")
  materialId    String?       @map("material_id")
  itemCode      String?       @map("item_code")
  description   String?       @map("item_description")
  profile       String?       @map("item_profile")
  grade         String?       @map("item_grade")
  unit          String?       @map("item_unit")
  quantity      Decimal
  unitPrice     Decimal       @map("unit_price")
  receivedQty   Decimal       @default(0) @map("received_qty")
  notes         String?
  material      Material?     @relation(fields: [materialId], references: [id])
  purchaseOrder PurchaseOrder @relation(fields: [poId], references: [id], onDelete: Cascade)

  @@index([poId])
  @@index([materialId])
  @@map("purchase_order_items")
}

model MillCertificate {
  id              String   @id @default(cuid())
  certNumber      String   @unique @map("cert_number")
  materialId      String   @map("material_id")
  vendorId        String   @map("vendor_id")
  heatNumber      String   @map("heat_number")
  grade           String?
  thickness       String?
  chemComposition Json?    @map("chem_composition")
  mechProperties  Json?    @map("mech_properties")
  fileUrl         String?  @map("file_url")
  isVerified      Boolean  @default(false) @map("is_verified")
  verifiedBy      String?  @map("verified_by")
  createdAt       DateTime @default(now()) @map("created_at")
  material        Material @relation(fields: [materialId], references: [id])
  vendor          Vendor   @relation(fields: [vendorId], references: [id])

  @@index([materialId])
  @@index([heatNumber])
  @@index([vendorId])
  @@map("mill_certificates")
}

model Workshop {
  id         String      @id @default(cuid())
  code       String      @unique
  name       String
  nameEn     String      @default("") @map("name_en")
  capacity   Int         @default(100)
  workOrders WorkOrder[]

  @@map("workshops")
}

model WorkOrder {
  id             String           @id @default(cuid())
  woCode         String           @unique @map("wo_code")
  projectId      String           @map("project_id")
  description    String
  teamCode       String           @map("team_code")
  status         String           @default("PENDING_MATERIAL")
  plannedStart   DateTime?        @map("planned_start")
  plannedEnd     DateTime?        @map("planned_end")
  actualStart    DateTime?        @map("actual_start")
  actualEnd      DateTime?        @map("actual_end")
  createdBy      String           @map("created_by")
  createdAt      DateTime         @default(now()) @map("created_at")
  updatedAt      DateTime         @updatedAt @map("updated_at")
  completedQty   Decimal?         @default(0) @map("completed_qty")
  quantity       Decimal?
  woType         String           @default("INTERNAL") @map("wo_type")
  workshopId     String?          @map("workshop_id")
  pieceMark      String?          @map("piece_mark")
  bomVersionId   String?          @map("bom_version_id")
  plannedWeight  Decimal?         @map("planned_weight")
  departmentId   String?          @map("department_id")
  deliveries            DeliveryRecord[]
  jobCards              JobCard[]
  materialIssues        MaterialIssue[]
  weldJoints            WeldJoint[]
  packingListItems      PackingListItem[]
  equipmentAssignments  EquipmentAssignment[]
  workPermits           WorkPermit[]
  project               Project          @relation(fields: [projectId], references: [id])
  workshop       Workshop?        @relation(fields: [workshopId], references: [id])
  bomVersion     BomVersion?      @relation(fields: [bomVersionId], references: [id])
  department     Department?      @relation(fields: [departmentId], references: [id])

  @@index([projectId])
  @@index([workshopId])
  @@index([status])
  @@index([bomVersionId])
  @@index([departmentId])
  @@index([pieceMark])
  @@map("work_orders")
}

model MaterialIssue {
  id          String    @id @default(cuid())
  workOrderId String    @map("work_order_id")
  materialId  String    @map("material_id")
  quantity    Decimal
  issuedBy    String    @map("issued_by")
  issuedAt    DateTime  @default(now()) @map("issued_at")
  notes       String?
  heatNumber  String?   @map("heat_number")
  material    Material  @relation(fields: [materialId], references: [id])
  workOrder   WorkOrder @relation(fields: [workOrderId], references: [id])

  @@index([workOrderId])
  @@index([materialId])
  @@index([heatNumber])
  @@map("material_issues")
}

model JobCard {
  id          String    @id @default(cuid())
  jobCode     String    @unique @map("job_code")
  workOrderId String    @map("work_order_id")
  teamCode    String    @map("team_code")
  workType    String    @map("work_type")
  description String?
  plannedQty  Decimal?  @map("planned_qty")
  actualQty   Decimal?  @map("actual_qty")
  unit        String    @default("kg")
  workDate    DateTime  @map("work_date")
  startTime   DateTime? @map("start_time")
  endTime     DateTime? @map("end_time")
  manpower    Int?
  status      String    @default("OPEN")
  reportedBy  String    @map("reported_by")
  approvedBy  String?   @map("approved_by")
  notes       String?
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  workOrder   WorkOrder @relation(fields: [workOrderId], references: [id])

  @@index([workOrderId])
  @@index([teamCode])
  @@index([workDate])
  @@index([status])
  @@map("job_cards")
}

model WeldJoint {
  id            String                @id @default(cuid())
  workOrderId   String                @map("work_order_id")
  jointNo       String                @map("joint_no")
  jointType     String                @default("BUTT") @map("joint_type")
  wpsNo         String?               @map("wps_no")
  welderId      String?               @map("welder_id")
  welderCertId  String?               @map("welder_cert_id")
  diameter      Decimal?
  thickness     Decimal?
  length        Decimal?
  status        String                @default("PENDING")
  weldedAt      DateTime?             @map("welded_at")
  ndtStatus     String?               @default("PENDING") @map("ndt_status")
  ndtMethod     String?               @map("ndt_method")
  ncrId         String?               @map("ncr_id")
  remarks       String?
  createdAt     DateTime              @default(now()) @map("created_at")
  updatedAt     DateTime              @updatedAt @map("updated_at")
  workOrder     WorkOrder             @relation(fields: [workOrderId], references: [id], onDelete: Cascade)
  welder        User?                 @relation("WelderJoints", fields: [welderId], references: [id])
  ncr           NonConformanceReport? @relation("WeldJointNCR", fields: [ncrId], references: [id])

  @@unique([workOrderId, jointNo])
  @@index([workOrderId])
  @@index([welderId])
  @@index([status])
  @@index([ndtStatus])
  @@map("weld_joints")
}

model Inspection {
  id             String           @id @default(cuid())
  projectId      String           @map("project_id")
  inspectionCode String           @unique @map("inspection_code")
  type           String
  stepCode       String           @map("step_code")
  status         String           @default("PENDING")
  inspectorId    String?          @map("inspector_id")
  inspectedAt    DateTime?        @map("inspected_at")
  resultData     Json?            @map("result_data")
  remarks        String?
  createdAt      DateTime         @default(now()) @map("created_at")
  updatedAt      DateTime         @updatedAt @map("updated_at")
  checklistItems InspectionItem[]
  project        Project          @relation(fields: [projectId], references: [id])

  @@index([projectId, type])
  @@index([status])
  @@map("inspections")
}

model InspectionItem {
  id           String     @id @default(cuid())
  inspectionId String     @map("inspection_id")
  checkItem    String     @map("check_item")
  standard     String?
  result       String?
  measurement  String?
  notes        String?
  inspection   Inspection @relation(fields: [inspectionId], references: [id], onDelete: Cascade)

  @@index([inspectionId])
  @@map("inspection_items")
}

model InspectionTestPlan {
  id          String          @id @default(cuid())
  itpCode     String          @unique @map("itp_code")
  projectId   String          @map("project_id")
  name        String
  revision    String          @default("R0")
  status      String          @default("DRAFT")
  approvedBy  String?         @map("approved_by")
  approvedAt  DateTime?       @map("approved_at")
  createdAt   DateTime        @default(now()) @map("created_at")
  updatedAt   DateTime        @updatedAt @map("updated_at")
  project     Project         @relation(fields: [projectId], references: [id])
  checkpoints ITPCheckpoint[]

  @@index([projectId])
  @@map("inspection_test_plans")
}

model ITPCheckpoint {
  id             String             @id @default(cuid())
  itpId          String             @map("itp_id")
